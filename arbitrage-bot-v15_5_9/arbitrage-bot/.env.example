# ── Environment ────────────────────────────────────────────
ENV=dev
DATABASE_URL=sqlite:///./arbitrage.db
SCAN_INTERVAL_MINUTES=10
CURRENCY=GBP
CURRENCY_SYMBOL=£

# Set to True to use the in-memory mock comp data for testing.
# Default False = always fetch live comps from eBay.
USE_MOCK_COMPS=False

# ── Categories to scan (v15.4.6) ────────────────────────────
# Comma-separated list. Default is phones-only for the focused
# validation phase. To enable everything: phones,shoes,laptops
CATEGORIES_ENABLED=phones

# ── Alert thresholds (Telegram only fires when ALL are met) ─
MIN_PROFIT=50
MIN_ROI=0.25
MIN_SCORE=0.60
MIN_CONFIDENCE=0.50

# ── Review thresholds (lower bar — appears on dashboard) ────
REVIEW_MIN_PROFIT=40
REVIEW_MIN_ROI=0.20
REVIEW_MIN_SCORE=0.20
REVIEW_MIN_CONFIDENCE=0.15

# ── Alert channels (leave blank to log to console only) ─────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# ── eBay API (get keys at https://developer.ebay.com) ───────
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE=EBAY_GB

# ── Fees (UK eBay defaults) ─────────────────────────────────
RESALE_FEE_PCT=0.13
PAYMENT_FEE_PCT=0.02
PAYMENT_FEE_FLAT=0.30
DEFAULT_OUTBOUND_SHIPPING=6.0
